# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/midas

# Server port (default: 3000)
# PORT=5001

# Storage mode: 's3' (MinIO/S3-compatible) or 'local' (filesystem)
STORAGE_MODE=s3

# MinIO / S3-compatible storage (only used when STORAGE_MODE=s3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=midas-attachments
